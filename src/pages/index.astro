---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>

  <body>
    <Header />

    <main class="container">

      <!-- HERO SECTION -->
      <section class="hero">
        <h1>🔥 Welcome to {SITE_TITLE}</h1>
        <p>
          Your daily source for <strong>Entertainment, Music, Celebrity News, Tech Updates & Biography Stories</strong>.
        </p>

        <div class="btn-group">
          <a href="/blog" class="btn">📰 Latest Posts</a>
          <a href="/categories/music" class="btn">🎵 Music</a>
          <a href="/categories/entertainment" class="btn">🎬 Entertainment</a>
          <a href="/categories/tech" class="btn">💻 Tech</a>
        </div>
      </section>

      <!-- TRENDING LINKS -->
      <section class="section">
        <h2>🔥 Trending Now</h2>

        <div class="grid">

          <a class="card" href="https://wikibiogram.com/" target="_blank">
            <h3>WikiBiogram</h3>
            <p>Celebrity biographies, music stars & entertainment profiles</p>
          </a>

          <a class="card" href="https://www.mytimeng.com/" target="_blank">
            <h3>MyTimeNG</h3>
            <p>Entertainment news, lifestyle & trending stories</p>
          </a>

          <a class="card" href="https://www.zeeloaded.com.ng/" target="_blank">
            <h3>ZeeLoaded</h3>
            <p>Music updates, celebrity gossip & viral content</p>
          </a>

          <a class="card" href="https://www.techmanly.com/" target="_blank">
            <h3>TechManly</h3>
            <p>Tech guides, online business & digital trends</p>
          </a>

        </div>
      </section>

      <!-- FEATURED ARTICLE AREA -->
      <section class="section featured">
        <h2>⭐ Featured Article</h2>

        <div class="featured-box">
          <h3>7 Websites Worth Checking Out Right Now</h3>
          <p>
            Explore top platforms for music, entertainment, biographies, tech and business insights.
          </p>

          <a class="btn" href="/blog">Read Full Article →</a>
        </div>
      </section>

      <!-- ABOUT SECTION -->
      <section class="section">
        <h2>About This Site</h2>
        <p>
          This platform brings together entertainment news, celebrity updates, music culture,
          tech insights, and biography stories in one place.
        </p>

        <p>
          Stay updated with trending stories, rising artists, viral content, and digital innovation.
        </p>
      </section>

    </main>

    <Footer />
  </body>
</html>

<style>
  .container {
    max-width: 1100px;
    margin: auto;
    padding: 20px;
  }

  .hero {
    text-align: center;
    padding: 60px 20px;
    background: #0f172a;
    color: white;
    border-radius: 12px;
  }

  .hero h1 {
    font-size: 2.2rem;
  }

  .btn-group {
    margin-top: 20px;
  }

  .btn {
    display: inline-block;
    padding: 10px 16px;
    margin: 5px;
    background: #2563eb;
    color: white;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 500;
  }

  .btn:hover {
    background: #1d4ed8;
  }

  .section {
    margin-top: 50px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 15px;
  }

  .card {
    padding: 15px;
    border-radius: 10px;
    background: #f1f5f9;
    text-decoration: none;
    color: black;
    transition: 0.2s;
  }

  .card:hover {
    transform: translateY(-3px);
    background: #e2e8f0;
  }

  .featured-box {
    padding: 20px;
    background: #111827;
    color: white;
    border-radius: 10px;
  }
</style>
